# Backend API Configuration
# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to app code.
# Use the deployed backend by default so phone-installed builds can connect.
EXPO_PUBLIC_API_URL=https://oursocialmediaproject-production-6f95.up.railway.app/api

# Optional legacy fallback:
API_URL=https://oursocialmediaproject-production-6f95.up.railway.app/api

# Alternative for Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# Alternative for iOS simulator:
# EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Alternative for a physical device hitting your local backend:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api
