# Backend API Configuration
# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to app code.
# Use your computer's IP address for physical devices.
EXPO_PUBLIC_API_URL=http://192.168.103.203:5000/api

# Optional legacy fallback:
API_URL=http://192.168.103.203:5000/api

# Alternative for Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# Alternative for iOS simulator:
# EXPO_PUBLIC_API_URL=http://localhost:5000/api
